{
  "name": "spy-game-room-app",
  "version": "1.0.0",
  "description": "Basic Spy game web app with online rooms using Express and Socket.io.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:load": "artillery run load-test.yml",
    "test:load:report": "artillery run load-test.yml --output report.json && artillery report report.json",
